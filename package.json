{
  "name": "indieweb",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["frontend/blog", "frontend/photos"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "npm run start --workspaces",
    "build": "npm run build --workspaces",
    "build:blog": "npm run build -w frontend/blog",
    "build:photos": "npm run build -w frontend/photos",
    "start:blog": "npm run start -w frontend/blog",
    "start:photos": "npm run start -w frontend/photos",
    "dev": "npm run start",
    "clean": "rm -rf frontend/blog/_site frontend/photos/_site node_modules"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}